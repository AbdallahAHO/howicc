---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getAuthenticatedPBClient } from '@/lib/auth';
import { UserConversationsResponseSchema, TagSchema } from '@howicc/schemas';

export const prerender = false;

// Check authentication
let currentUser = null;
let conversations: any[] = [];
let total = 0;

try {
  const authResult = await getAuthenticatedPBClient(Astro.request);
  currentUser = authResult?.user || null;

  if (currentUser) {
    // Fetch all user's conversations (no pagination - handled client-side)
    const apiUrl = new URL('/api/conversations/user', Astro.url.origin);

    const response = await fetch(apiUrl.toString(), {
      headers: {
        Cookie: Astro.request.headers.get('cookie') || '',
      },
    });

    if (response.ok) {
      const data = await response.json();
      const validated = UserConversationsResponseSchema.parse(data);
      conversations = validated.conversations;
      total = validated.total;
    }
  }
} catch (error) {
  console.error('Error loading dashboard:', error);
}
---

<BaseLayout
  title="My Conversations | HowiCC"
  description="Manage and view all your conversations"
>
  {!currentUser ? (
    <div class="max-w-4xl mx-auto px-4 py-12">
      <div class="bg-blue-50 border-l-4 border-blue-400 p-4 mb-8">
        <div class="flex">
          <div class="shrink-0">
            <svg class="h-5 w-5 text-blue-400" viewBox="0 0 20 20" fill="currentColor">
              <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z" clip-rule="evenodd" />
            </svg>
          </div>
          <div class="ml-3">
            <p class="text-sm text-blue-700">
              <strong>Sign in required:</strong> Please <a href="/login" class="underline font-medium">sign in</a> or <a href="/register" class="underline font-medium">create an account</a> to view your conversations.
            </p>
          </div>
        </div>
      </div>
    </div>
  ) : (
    <div class="max-w-7xl mx-auto px-4 py-8">
      <!-- Header -->
      <div class="mb-8 flex justify-between items-center">
        <div>
          <h1 class="text-4xl font-bold text-base-900 mb-2">My Conversations</h1>
          <p class="text-base-600">
            {total === 0 ? 'No conversations yet' : `${total} conversation${total === 1 ? '' : 's'}`}
          </p>
        </div>
        <div class="flex gap-3">
          <a
            href="/settings"
            class="px-4 py-2 bg-white border border-base-300 text-base-900 rounded-lg hover:bg-base-50 transition-colors text-sm font-medium"
          >
            API Keys
          </a>
          <a
            href="/"
            class="px-4 py-2 bg-primary-600 text-white rounded-lg hover:bg-primary-700 transition-colors text-sm font-medium"
          >
            Upload New
          </a>
        </div>
      </div>

      <!-- Filters -->
      <div class="mb-6 flex flex-wrap gap-3 items-center">
        <span class="text-sm font-medium text-base-700">Filter:</span>
        <button
          id="filter-all"
          class="filter-btn active px-3 py-1.5 text-sm rounded-lg border transition-colors bg-primary-600 text-white border-primary-600"
        >
          All
        </button>
        <button
          id="filter-private"
          class="filter-btn px-3 py-1.5 text-sm rounded-lg border transition-colors bg-white text-base-700 border-base-300 hover:bg-base-50"
          data-visibility="private"
        >
          Private
        </button>
        <button
          id="filter-unlisted"
          class="filter-btn px-3 py-1.5 text-sm rounded-lg border transition-colors bg-white text-base-700 border-base-300 hover:bg-base-50"
          data-visibility="unlisted"
        >
          Unlisted
        </button>
        <button
          id="filter-public"
          class="filter-btn px-3 py-1.5 text-sm rounded-lg border transition-colors bg-white text-base-700 border-base-300 hover:bg-base-50"
          data-visibility="public"
        >
          Public
        </button>
      </div>

      <!-- Conversations List -->
      {conversations.length === 0 ? (
        <div class="bg-white rounded-lg border border-base-200 p-12 text-center">
          <svg class="mx-auto h-12 w-12 text-base-400 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
          </svg>
          <h3 class="text-lg font-semibold text-base-900 mb-2">No conversations yet</h3>
          <p class="text-base-600 mb-6">Get started by uploading your first conversation using the CLI.</p>
          <a
            href="/settings"
            class="inline-block px-4 py-2 bg-primary-600 text-white rounded-lg hover:bg-primary-700 transition-colors text-sm font-medium"
          >
            Set up CLI
          </a>
        </div>
      ) : (
        <div id="conversations-list" class="space-y-4">
          {conversations.map((conv) => (
            <div
              class="conversation-card bg-white rounded-lg border border-base-200 p-6 hover:shadow-md transition-shadow"
              data-visibility={conv.visibility}
            >
              <div class="flex items-start justify-between gap-4">
                <div class="flex-1 min-w-0">
                  <div class="flex items-start gap-3 mb-2">
                    <h3 class="text-lg font-semibold text-base-900 flex-1">
                      <a href={`/p/${conv.slug}`} class="hover:text-primary-600 transition-colors">
                        {conv.title}
                      </a>
                    </h3>
                    <!-- Visibility Badge -->
                    <span
                      class={`px-2 py-1 text-xs font-medium rounded-full shrink-0 ${
                        conv.visibility === 'private'
                          ? 'bg-red-100 text-red-800'
                          : conv.visibility === 'unlisted'
                          ? 'bg-yellow-100 text-yellow-800'
                          : 'bg-green-100 text-green-800'
                      }`}
                    >
                      {conv.visibility === 'private' ? '🔒 Private' : conv.visibility === 'unlisted' ? '🔗 Unlisted' : '🌐 Public'}
                    </span>
                  </div>

                  <!-- Summary -->
                  {conv.summary && (
                    <p class="text-base-600 mb-3 line-clamp-2">{conv.summary}</p>
                  )}

                  <!-- Tags -->
                  {conv.tags && conv.tags.length > 0 && (
                    <div class="flex flex-wrap gap-2 mb-3">
                      {conv.tags.map((tag: any) => (
                        <span class="px-2 py-1 text-xs bg-base-100 text-base-700 rounded-md">
                          {tag.name}
                        </span>
                      ))}
                    </div>
                  )}

                  <!-- Metadata -->
                  <div class="flex flex-wrap items-center gap-4 text-sm text-base-500">
                    <span>Created {new Date(conv.created).toLocaleDateString()}</span>
                    {conv.viewsTotal > 0 && (
                      <span>👁️ {conv.viewsTotal} view{conv.viewsTotal === 1 ? '' : 's'}</span>
                    )}
                    {conv.publicSince && (
                      <span>Published {new Date(conv.publicSince).toLocaleDateString()}</span>
                    )}
                  </div>
                </div>
                <a
                  href={`/p/${conv.slug}`}
                  class="text-primary-600 hover:text-primary-700 font-medium shrink-0"
                >
                  View →
                </a>
              </div>
            </div>
          ))}
        </div>
      )}
    </div>
  )}
</BaseLayout>

<script>
  // Filter conversations by visibility
  const filterButtons = document.querySelectorAll('.filter-btn');
  const conversationCards = document.querySelectorAll('.conversation-card');

  filterButtons.forEach(btn => {
    btn.addEventListener('click', () => {
      // Update active state
      filterButtons.forEach(b => {
        b.classList.remove('active', 'bg-primary-600', 'text-white', 'border-primary-600');
        b.classList.add('bg-white', 'text-base-700', 'border-base-300');
      });
      btn.classList.add('active', 'bg-primary-600', 'text-white', 'border-primary-600');
      btn.classList.remove('bg-white', 'text-base-700', 'border-base-300');

      // Filter conversations
      const visibility = btn.dataset.visibility;

      conversationCards.forEach(card => {
        if (!visibility || card.dataset.visibility === visibility) {
          card.style.display = '';
        } else {
          card.style.display = 'none';
        }
      });
    });
  });
</script>

<style>
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
