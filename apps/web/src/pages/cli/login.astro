---
import Layout from '../../components/Layout.astro'
import type { WebLocals } from '../../lib/auth/types'

const callbackUrl = Astro.url.searchParams.get('callbackUrl') ?? ''
const codeChallenge = Astro.url.searchParams.get('codeChallenge') ?? ''
const state = Astro.url.searchParams.get('state') ?? ''
const locals = Astro.locals as WebLocals
const authApiUrl = locals.authApiUrl

if (!locals.auth.user) {
  return Astro.redirect(
    `/login?returnTo=${encodeURIComponent(`${Astro.url.pathname}${Astro.url.search}`)}`,
  )
}
---

<Layout title="Authorize CLI">
  <main class="grid min-h-dvh place-items-center px-4 py-16">
    <div class="w-full max-w-md">
      <div class="bg-card text-card-foreground rounded-2xl border p-8 shadow-sm">
        <h1 class="text-2xl font-semibold tracking-tight">Authorize CLI</h1>
        <p class="text-muted-foreground mt-2 text-sm">
          You're signed in as <strong class="text-foreground">{locals.auth.user.email}</strong>.
        </p>
        <p class="text-muted-foreground mt-3 text-sm">
          Continue to hand a one-time code back to the local HowiCC CLI process running on your machine.
        </p>

        <button
          id="continue-cli-login"
          data-api-url={authApiUrl}
          data-callback-url={callbackUrl}
          data-code-challenge={codeChallenge}
          data-state={state}
          class="bg-primary text-primary-foreground hover:bg-primary/90 mt-6 inline-flex h-11 w-full items-center justify-center rounded-md px-6 text-sm font-medium transition-colors"
        >
          Continue in CLI
        </button>
        <p id="cli-auth-status" class="text-muted-foreground mt-3 text-center text-xs">Waiting to continue…</p>
      </div>
    </div>
  </main>

  <script>
    import { wireCliLoginPage } from '../../lib/auth/browser/cli-login-page'
    wireCliLoginPage()
  </script>
</Layout>
