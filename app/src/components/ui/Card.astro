---
interface Props {
  class?: string;
  hover?: boolean;
}

const {
  class: className = '',
  hover = false,
} = Astro.props;

const baseClasses = 'bg-white rounded-3xl border border-base-200';
const hoverClasses = hover ? 'hover:border-primary-300 transition-all' : '';
const classes = `${baseClasses} ${hoverClasses} ${className}`;
---

<div class={classes}>
  <slot />
</div>
