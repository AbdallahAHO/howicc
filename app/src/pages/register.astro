---
import BaseLayout from '@/layouts/BaseLayout.astro';

export const prerender = false;
---

<BaseLayout
  title="Register | How I Claude Code"
  description="Create your How I Claude Code account and get your API key"
>
  <div class="flex items-center justify-center min-h-[calc(100vh-12rem)]">
    <div class="flex items-center justify-center w-full lg:w-2/3">
      <div class="w-full max-w-md py-24 lg:py-32">
        <div id="success-message" class="hidden bg-white rounded-lg border border-base-200 p-8">
          <div class="text-center mb-6">
            <div class="inline-flex items-center justify-center w-16 h-16 bg-green-100 rounded-full mb-4">
              <svg class="w-8 h-8 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
            </div>
            <h2 class="text-2xl font-bold text-base-900 mb-2">Account Created!</h2>
            <p class="text-base-600 mb-6">Your account has been successfully created.</p>
          </div>

          <div class="mb-6">
            <label class="block text-sm font-medium text-base-700 mb-2">
              Your API Key
              <span class="text-red-600 ml-1">(Save this now - you won't see it again!)</span>
            </label>
            <div class="flex items-center gap-2">
              <input
                type="text"
                readonly
                class="flex-1 px-4 py-3 border border-base-300 rounded-lg bg-base-50 font-mono text-sm"
                id="api-key-display"
              />
              <button
                onclick="copyApiKey()"
                class="px-4 py-3 bg-primary-600 text-white rounded-lg hover:bg-primary-700 transition-colors whitespace-nowrap"
                id="copy-btn"
              >
                Copy
              </button>
            </div>
            <p class="mt-2 text-sm text-base-600">
              Use this API key to configure the How I Claude Code CLI and upload your conversations.
            </p>
          </div>

          <div class="border-t border-base-200 pt-6">
            <h3 class="font-semibold text-base-900 mb-3">Next Steps:</h3>
            <ol class="list-decimal list-inside space-y-2 text-sm text-base-700">
              <li>Save your API key in a secure location</li>
              <li>Configure the CLI with: <code class="px-1 py-0.5 bg-base-100 rounded">npx @howicc/cli config</code></li>
              <li>Start syncing: <code class="px-1 py-0.5 bg-base-100 rounded">npx @howicc/cli sync</code></li>
            </ol>
          </div>

          <div class="mt-6">
            <a
              href="/settings"
              class="block w-full text-center px-4 py-3 bg-base-900 text-white rounded-lg hover:bg-base-800 transition-colors font-medium"
            >
              Go to Settings
            </a>
          </div>
        </div>

        <div id="register-form-container">
          <div>
            <h1 class="text-xl md:text-2xl lg:text-3xl font-semibold tracking-tight text-base-900">
              Start sharing your Claude conversations
            </h1>
            <p class="text-base mt-2 text-base-600 text-balance">
              Get your API key, sync your conversations, and share beautiful links with AI-powered summaries and tags.
            </p>
          </div>

          <form id="register-form" class="mt-10 space-y-4">
            <div id="error" class="hidden p-4 bg-red-50 border border-red-200 rounded-lg">
              <p class="text-sm text-red-800"></p>
            </div>

              <div class="w-full">
                <div class="flex justify-between items-baseline mb-1">
                  <label for="email" class="font-medium text-base-600 text-sm">Email Address</label>
                </div>
                <div class="relative z-0 focus-within:z-10">
                  <div class="absolute inset-y-0 left-0 flex items-center pl-3 pointer-events-none">
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      class="size-4 text-base-500"
                    >
                      <path stroke="none" d="M0 0h24v24H0z" fill="none"></path>
                      <path
                        d="M3 7a2 2 0 0 1 2 -2h14a2 2 0 0 1 2 2v10a2 2 0 0 1 -2 2h-14a2 2 0 0 1 -2 -2v-10z"
                      ></path>
                      <path d="M3 7l9 6l9 -6"></path>
                    </svg>
                  </div>
            <input
                    placeholder="you@example.com"
              id="email"
              name="email"
                    type="email"
              required
                    class="w-full block transition duration-300 ease-in-out leading-tight align-middle focus:z-10 pl-10 h-10 px-4 py-2 text-sm rounded-md bg-white border border-transparent text-base-700 ring-1 ring-base-200 placeholder-base-400 focus:border-primary-500 focus:ring-primary-100 focus:ring-2 focus:outline-none shadow-sm"
                    inputmode="email"
            />
                </div>
          </div>

              <div class="w-full">
                <div class="flex justify-between items-baseline mb-1">
                  <label for="password" class="font-medium text-base-600 text-sm">Password</label>
                </div>
                <div
                  class="relative z-0 focus-within:z-10"
                  x-data="{ value: '', showPassword: false }"
                >
            <input
                    placeholder="••••••••"
                    required
              id="password"
              name="password"
                    x-model="value"
                    x-bind:type="showPassword ? 'text' : 'password'"
              minlength="8"
                    class="w-full block transition duration-300 ease-in-out leading-tight align-middle focus:z-10 h-10 px-4 py-2 text-sm rounded-md bg-white border border-transparent text-base-700 ring-1 ring-base-200 placeholder-base-400 focus:border-primary-500 focus:ring-primary-100 focus:ring-2 focus:outline-none shadow-sm"
                    aria-required="true"
                  />
                  <div class="absolute inset-y-0 right-0 flex items-center pr-3 gap-2">
                    <button
                      type="button"
                      @click="showPassword = !showPassword"
                      class="text-base-500 focus:outline-none"
                      tabindex="-1"
                      aria-label="Toggle password visibility"
                    >
                      <svg
                        xmlns="http://www.w3.org/2000/svg"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        class="size-4"
                        x-show="!showPassword"
                      >
                        <path stroke="none" d="M0 0h24v24H0z" fill="none"></path>
                        <path d="M10 12a2 2 0 1 0 4 0a2 2 0 0 0 -4 0"></path>
                        <path
                          d="M21 12c-2.4 4 -5.4 6 -9 6c-3.6 0 -6.6 -2 -9 -6c2.4 -4 5.4 -6 9 -6c3.6 0 6.6 2 9 6"
                        ></path>
                      </svg>
                      <svg
                        xmlns="http://www.w3.org/2000/svg"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        class="size-4"
                        x-show="showPassword"
                      >
                        <path stroke="none" d="M0 0h24v24H0z" fill="none"></path>
                        <path d="M10.585 10.587a2 2 0 0 0 2.829 2.828"></path>
                        <path
                          d="M16.681 16.673a8.717 8.717 0 0 1 -4.681 1.327c-3.6 0 -6.6 -2 -9 -6c1.272 -2.12 2.712 -3.678 4.32 -4.674m2.86 -1.146a9.055 9.055 0 0 1 1.82 -.18c3.6 0 6.6 2 9 6c-.666 1.11 -1.379 2.067 -2.138 2.87"
                        ></path>
                        <path d="M3 3l18 18"></path>
                      </svg>
                    </button>
                    <button
                      x-show="value"
                      type="button"
                      @click="value = ''"
                      class="text-base-400 hover:text-base-600 focus:outline-none"
                      aria-label="Clear input"
                    >
                      <svg
                        xmlns="http://www.w3.org/2000/svg"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        class="size-4 text-base-500"
                      >
                        <path stroke="none" d="M0 0h24v24H0z" fill="none"></path>
                        <path d="M18 6l-12 12"></path>
                        <path d="M6 6l12 12"></path>
                      </svg>
                    </button>
                  </div>
                </div>
                <p class="mt-1 text-xs text-base-500">Minimum 8 characters</p>
          </div>

              <div class="w-full">
                <div class="flex justify-between items-baseline mb-1">
                  <label for="confirm-password" class="font-medium text-base-600 text-sm">Confirm Password</label>
                </div>
                <div
                  class="relative z-0 focus-within:z-10"
                  x-data="{ value: '', showPassword: false }"
                >
            <input
                    placeholder="••••••••"
                    required
                    id="confirm-password"
              name="passwordConfirm"
                    x-model="value"
                    x-bind:type="showPassword ? 'text' : 'password'"
              minlength="8"
                    class="w-full block transition duration-300 ease-in-out leading-tight align-middle focus:z-10 h-10 px-4 py-2 text-sm rounded-md bg-white border border-transparent text-base-700 ring-1 ring-base-200 placeholder-base-400 focus:border-primary-500 focus:ring-primary-100 focus:ring-2 focus:outline-none shadow-sm"
                    aria-required="true"
                  />
                  <div class="absolute inset-y-0 right-0 flex items-center pr-3 gap-2">
                    <button
                      type="button"
                      @click="showPassword = !showPassword"
                      class="text-base-500 focus:outline-none"
                      tabindex="-1"
                      aria-label="Toggle password visibility"
                    >
                      <svg
                        xmlns="http://www.w3.org/2000/svg"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        class="size-4"
                        x-show="!showPassword"
                      >
                        <path stroke="none" d="M0 0h24v24H0z" fill="none"></path>
                        <path d="M10 12a2 2 0 1 0 4 0a2 2 0 0 0 -4 0"></path>
                        <path
                          d="M21 12c-2.4 4 -5.4 6 -9 6c-3.6 0 -6.6 -2 -9 -6c2.4 -4 5.4 -6 9 -6c3.6 0 6.6 2 9 6"
                        ></path>
                      </svg>
                      <svg
                        xmlns="http://www.w3.org/2000/svg"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        class="size-4"
                        x-show="showPassword"
                      >
                        <path stroke="none" d="M0 0h24v24H0z" fill="none"></path>
                        <path d="M10.585 10.587a2 2 0 0 0 2.829 2.828"></path>
                        <path
                          d="M16.681 16.673a8.717 8.717 0 0 1 -4.681 1.327c-3.6 0 -6.6 -2 -9 -6c1.272 -2.12 2.712 -3.678 4.32 -4.674m2.86 -1.146a9.055 9.055 0 0 1 1.82 -.18c3.6 0 6.6 2 9 6c-.666 1.11 -1.379 2.067 -2.138 2.87"
                        ></path>
                        <path d="M3 3l18 18"></path>
                      </svg>
                    </button>
                    <button
                      x-show="value"
                      type="button"
                      @click="value = ''"
                      class="text-base-400 hover:text-base-600 focus:outline-none"
                      aria-label="Clear input"
                    >
                      <svg
                        xmlns="http://www.w3.org/2000/svg"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        class="size-4 text-base-500"
                      >
                        <path stroke="none" d="M0 0h24v24H0z" fill="none"></path>
                        <path d="M18 6l-12 12"></path>
                        <path d="M6 6l12 12"></path>
                      </svg>
                    </button>
                  </div>
                </div>
          </div>

              <p class="text-xs font-medium text-base-500">
                By creating an account, you agree to our
                <a href="/terms" class="font-medium text-primary-600 hover:text-primary-700">Terms of service</a>
                and
                <a href="/privacy" class="font-medium text-primary-600 hover:text-primary-700">Privacy Policy</a>
              </p>

          <button
            type="submit"
            id="submit-btn"
                class="relative flex items-center justify-center text-center font-medium transition-colors duration-200 ease-in-out select-none focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:z-10 rounded-md w-full text-white bg-base-900 outline outline-base-900 hover:bg-base-950 focus-visible:outline-base-950 h-10 px-5 text-sm disabled:bg-base-400 disabled:cursor-not-allowed"
          >
                Create account
          </button>
        </form>

            <p class="text-xs mt-4 font-medium text-base-500">
            Already have an account?
              <a href="/login" class="font-medium text-primary-600 hover:text-primary-700">Sign in</a>
            </p>
        </div>
      </div>
    </div>

    <div class="relative hidden overflow-hidden bg-white border-8 border-white lg:block lg:w-1/3 lg:order-first">
      <div class="absolute inset-0 bg-linear-to-br from-primary-600 via-primary-700 to-primary-800 rounded-2xl"></div>
      <div
        aria-hidden="true"
        class="absolute inset-0 pointer-events-none bg-base-900/40 rounded-2xl"
      ></div>
      <div class="absolute inset-0 flex flex-col items-start justify-between p-8">
        <div>
          <a href="/">
            <span class="sr-only">Back to home</span>
            <div class="text-2xl font-bold text-white mb-12">💬 How I Claude Code</div>
          </a>
          <h1 class="text-xl sm:text-xl md:text-2xl mt-12 font-semibold text-white text-shadow-sm text-balance">
            Share your Claude conversations with the world
          </h1>
          <p class="text-sm mt-2 text-white/90 text-shadow-sm">
            Transform your local Claude Code chats into beautiful, shareable links with AI-powered summaries, automatic tags, and syntax highlighting.
          </p>
        </div>
        <div>
          <div class="w-full p-6 shadow bg-base-900/30 backdrop-blur rounded-xl border border-white/10">
            <div class="relative flex flex-col gap-2">
              <h3 class="text-base text-white">
                "Finally, a way to share my Claude conversations without screenshots. The AI summaries make it so easy to find what I'm looking for."
              </h3>
              <div class="flex items-center mt-2 gap-4">
                <div class="size-10 bg-primary-500 rounded-full flex items-center justify-center text-white font-semibold">
                  DC
                </div>
                <div>
                  <p class="text-base font-semibold text-white">Developer</p>
                  <p class="text-xs text-white/80">Claude Code User</p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>

<script>
  const form = document.getElementById('register-form') as HTMLFormElement;
  const errorDiv = document.getElementById('error') as HTMLDivElement;
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
  const formContainer = document.getElementById('register-form-container') as HTMLDivElement;
  const successMessage = document.getElementById('success-message') as HTMLDivElement;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();

    const formData = new FormData(form);
    const email = formData.get('email') as string;
    const password = formData.get('password') as string;
    const passwordConfirm = formData.get('passwordConfirm') as string;

    // Hide error
    errorDiv.classList.add('hidden');

    // Disable button
    submitBtn.disabled = true;
    submitBtn.textContent = 'Creating account...';

    try {
      const response = await fetch('/api/register', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
        },
        credentials: 'include',
        body: JSON.stringify({ email, password, passwordConfirm }),
      });

      const data = await response.json();

      if (!response.ok) {
        // Type-safe error handling - API returns validated APIErrorSchema
        const errorMessage = data?.error || 'Registration failed';
        throw new Error(errorMessage);
      }

      // Type-safe success handling - API returns validated RegisterResponseSchema
      // Response is validated server-side, so we can trust the structure
      if (data.success && data.user && data.apiKey) {
        // Show success message with API key
        const apiKeyInput = document.getElementById('api-key-display') as HTMLInputElement;
        if (apiKeyInput) {
          apiKeyInput.value = data.apiKey;
        }
      } else {
        throw new Error('Invalid response format');
      }

      formContainer.classList.add('hidden');
      successMessage.classList.remove('hidden');
    } catch (err: any) {
      console.error('Registration error:', err);

      // Show error
      const errorText = errorDiv.querySelector('p');
      if (errorText) {
        errorText.textContent = err?.message || 'Registration failed. Please try again.';
      }
      errorDiv.classList.remove('hidden');

      // Re-enable button
      submitBtn.disabled = false;
      submitBtn.textContent = 'Create account';
    }
  });

  function copyApiKey() {
    const input = document.getElementById('api-key-display') as HTMLInputElement;
    const button = document.getElementById('copy-btn') as HTMLButtonElement;

    if (!input || !button) return;

    navigator.clipboard.writeText(input.value).then(() => {
      const originalText = button.textContent;
      button.textContent = 'Copied!';
      button.classList.add('bg-green-600');
      button.classList.remove('bg-primary-600', 'hover:bg-primary-700');

      setTimeout(() => {
        button.textContent = originalText;
        button.classList.remove('bg-green-600');
        button.classList.add('bg-primary-600', 'hover:bg-primary-700');
      }, 2000);
    });
  }

  // Make function globally accessible
  (window as any).copyApiKey = copyApiKey;
</script>
