{
  "name": "@howicc/web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "homepage": "https://howi.cc",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AbdallahAHO/howicc.git",
    "directory": "apps/web"
  },
  "bugs": {
    "url": "https://github.com/AbdallahAHO/howicc/issues"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "deploy:prod": "pnpm run build && pnpm exec wrangler deploy --config dist/server/wrangler.json --domains howi.cc",
    "deploy:check": "pnpm run build && pnpm exec wrangler deploy --config dist/server/wrangler.json --domains howi.cc --dry-run",
    "cf:deploy": "pnpm run deploy:prod",
    "test": "vitest run --passWithNoTests",
    "type-check": "astro check"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.8",
    "@astrojs/cloudflare": "^13.1.10",
    "@astrojs/react": "^5.0.3",
    "@howicc/api-client": "workspace:*",
    "@howicc/auth": "workspace:*",
    "@howicc/ui": "workspace:*",
    "@howicc/ui-web": "workspace:*",
    "@tailwindcss/vite": "^4.1.7",
    "astro": "^6.1.7",
    "envin": "^1.2.0",
    "lucide-react": "^0.562.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "tailwindcss": "^4.1.7",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "typescript": "^5.9.3",
    "vitest": "^4.1.4"
  }
}
