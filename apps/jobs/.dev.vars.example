# Cloudflare Worker variables for local jobs development.
# Copy to `apps/jobs/.dev.vars` when wiring wrangler locally.

APP_ENV="development"
PRODUCT_NAME="HowiCC"
JOBS_WORKER_NAME="howicc-jobs"
API_BASE_URL="http://localhost:8787"

BETTER_AUTH_SECRET="dev-better-auth-secret-change-me-please"
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

DB_PROVIDER="d1"
DATABASE_URL=""

STORAGE_PROVIDER="r2"
STORAGE_BUCKET_NAME=""
STORAGE_REGION="auto"
STORAGE_ENDPOINT=""
STORAGE_ACCESS_KEY_ID=""
STORAGE_SECRET_ACCESS_KEY=""
