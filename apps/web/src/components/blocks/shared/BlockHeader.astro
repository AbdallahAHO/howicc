---
import { Badge } from '@howicc/ui-web/badge'

type Props = {
  eyebrow?: string
  title: string
  meta?: string
  count?: number
  class?: string
}

const { eyebrow, title, meta, count, class: className } = Astro.props
---

<div class:list={['flex min-w-0 items-start justify-between gap-3', className]}>
  <div class="flex min-w-0 flex-col gap-0.5">
    {eyebrow ? (
      <p class="text-muted-foreground text-[0.6875rem] font-medium tracking-wide uppercase">
        {eyebrow}
      </p>
    ) : null}
    <p class="text-foreground truncate text-sm font-medium">{title}</p>
    {meta ? (
      <p class="text-muted-foreground truncate text-xs">{meta}</p>
    ) : null}
  </div>
  <div class="flex shrink-0 items-center gap-2">
    {typeof count === 'number' ? (
      <Badge variant="outline" className="tabular-nums">{count}</Badge>
    ) : null}
    <slot name="action" />
  </div>
</div>
