---
import '../styles/globals.css'
import type { WebLocals } from '../lib/auth/types'

type Props = {
  title?: string
  bodyClass?: string
}

const { title, bodyClass = 'bg-background text-foreground' } = Astro.props
const locals = Astro.locals as WebLocals
const fullTitle = title ? `${title} · ${locals.productName}` : locals.productName
---

<!doctype html>
<html lang="en" class="h-full antialiased">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="color-scheme" content="light dark" />
    <title>{fullTitle}</title>
  </head>
  <body class={`isolate min-h-dvh ${bodyClass}`}>
    <slot />
  </body>
</html>
