---
// Footer component
---

<footer class="w-full border-t border-base-200 bg-white/80 backdrop-blur supports-[backdrop-filter]:bg-white/60">
  <div class="px-6 mx-auto max-w-screen-xl md:px-10 lg:px-16 py-12">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-8">
      <!-- Brand -->
      <div class="col-span-1 md:col-span-2">
        <a href="/" class="inline-flex items-center gap-2 mb-4">
          <span class="text-2xl font-bold text-base-900">💬</span>
          <span class="text-lg font-semibold text-base-900">How I Claude Code</span>
        </a>
        <p class="text-sm text-base-600 mb-4 max-w-md">
          Transform your Claude Code conversations into beautifully formatted, shareable links with AI-powered summaries and tags.
        </p>
        <div class="flex items-center gap-4">
          <a
            href="https://github.com/AbdallahAHO/howicc"
            target="_blank"
            rel="noopener"
            class="text-base-500 hover:text-base-900 transition-colors"
            aria-label="GitHub"
          >
            <svg class="size-5" fill="currentColor" viewBox="0 0 24 24">
              <path
                fill-rule="evenodd"
                d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"
                clip-rule="evenodd"
              />
            </svg>
          </a>
        </div>
      </div>

      <!-- Links -->
      <div>
        <h3 class="text-sm font-semibold text-base-900 mb-4">Product</h3>
        <ul class="space-y-2">
          <li>
            <a href="/#get-started" class="text-sm text-base-600 hover:text-base-900 transition-colors">
              Features
            </a>
          </li>
          <li>
            <a href="/register" class="text-sm text-base-600 hover:text-base-900 transition-colors">
              Get Started
            </a>
          </li>
          <li>
            <a href="/leaderboard" class="text-sm text-base-600 hover:text-base-900 transition-colors">
              Leaderboard
            </a>
          </li>
          <li>
            <a href="https://github.com/AbdallahAHO/howicc" target="_blank" rel="noopener" class="text-sm text-base-600 hover:text-base-900 transition-colors">
              Documentation
            </a>
          </li>
        </ul>
      </div>

      <div>
        <h3 class="text-sm font-semibold text-base-900 mb-4">Legal</h3>
        <ul class="space-y-2">
          <li>
            <a href="/privacy" class="text-sm text-base-600 hover:text-base-900 transition-colors">
              Privacy Policy
            </a>
          </li>
          <li>
            <a href="/terms" class="text-sm text-base-600 hover:text-base-900 transition-colors">
              Terms of Service
            </a>
          </li>
          <li>
            <a href="/dmca" class="text-sm text-base-600 hover:text-base-900 transition-colors">
              DMCA
            </a>
          </li>
        </ul>
      </div>
    </div>

    <div class="mt-8 pt-8 border-t border-base-200">
      <p class="text-sm text-center text-base-500">
        &copy; {new Date().getFullYear()} How I Claude Code. Share your Claude conversations.
      </p>
    </div>
  </div>
</footer>
