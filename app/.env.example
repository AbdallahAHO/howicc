# ============================================
# How I Claude Code - Environment Configuration
# ============================================
# Copy this file to .env and fill in your values
# cp .env.example .env

# ============================================
# PocketBase Configuration
# ============================================
# URL where PocketBase is running (internal network only, not public)
# Example: http://127.0.0.1:8090 or http://localhost:8090
PB_URL=http://127.0.0.1:8090

# PocketBase admin credentials
# These are used to authenticate server-side operations
PB_ADMIN_EMAIL=your-admin@email.com
PB_ADMIN_PASSWORD=your-secure-password

# ============================================
# API Security
# ============================================
# Generate a secure random API key for server authentication
# You can generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SERVER_API_KEY=your-random-api-key-here

# ============================================
# OpenRouter AI Configuration
# ============================================
# Your OpenRouter API key for AI-powered conversation analysis
# Get one at: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-...

# AI model to use for conversation analysis
# Popular options:
#   - anthropic/claude-3.5-sonnet (default, recommended)
#   - anthropic/claude-3-opus (more powerful, slower, more expensive)
#   - anthropic/claude-3-haiku (faster, cheaper, less capable)
#   - openai/gpt-4-turbo (alternative)
#   - openai/gpt-4o (latest OpenAI model)
# See https://openrouter.ai/models for full list
OPENROUTER_MODEL=anthropic/claude-3.5-sonnet

# ============================================
# Public Site Configuration
# ============================================
# Your site's public URL (used for CORS, OAuth callbacks, etc.)
# Examples:
#   Development: http://localhost:4321
#   Production: https://yourdomain.com
PUBLIC_SITE_URL=http://localhost:4321

# ============================================
# Optional: Advanced Configuration
# ============================================
# Uncomment and configure if needed:

# CORS origin (defaults to PUBLIC_SITE_URL if not set)
# CORS_ORIGIN=http://localhost:4321

# Node environment (development, production, test)
# NODE_ENV=development
