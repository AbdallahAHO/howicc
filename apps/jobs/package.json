{
  "name": "@howicc/jobs",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm exec wrangler dev --config wrangler.jsonc --port 8788 --ip 127.0.0.1",
