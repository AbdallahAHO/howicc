---
/**
 * Vertical connector used by block bodies that render a timeline of
 * items (task_timeline, and later the phase spine once we align them).
 *
 * Renders the dot + optional connector; the caller controls spacing and
 * puts content in the default slot.
 */

type Props = {
  first?: boolean
  last?: boolean
  glyph?: string
  tone?: 'default' | 'info' | 'warning' | 'error' | 'success'
  class?: string
}

const {
  first = false,
  last = false,
  glyph = '▸',
  tone = 'default',
  class: className,
} = Astro.props

const iconClass =
  tone === 'info'
    ? 'border-info/15 bg-info/10 text-info'
    : tone === 'warning'
      ? 'border-warning/15 bg-warning/10 text-warning'
      : tone === 'error'
        ? 'border-destructive/15 bg-destructive/10 text-destructive'
        : tone === 'success'
          ? 'border-success/15 bg-success/10 text-success'
          : 'border-border bg-background text-ink-secondary'
---

<div class:list={['relative flex gap-4', className]}>
  <div class="relative flex w-8 shrink-0 flex-col items-center" aria-hidden="true">
    <span
      class:list={[
        'bg-border w-px flex-none',
        first ? 'h-3 opacity-0' : 'h-3',
      ]}
    ></span>
    <span
      class:list={[
        'relative z-10 inline-flex size-8 shrink-0 items-center justify-center rounded-pill border text-[0.8125rem] shadow-subtle',
        iconClass,
      ]}
    >
      <span class="font-mono leading-none">{glyph}</span>
    </span>
    <span
      class:list={[
        'bg-border w-px flex-1',
        last ? 'opacity-0' : '',
      ]}
    ></span>
  </div>
  <div class="min-w-0 flex-1 pb-4 pt-0.5">
    <slot />
  </div>
</div>
