---
interface Props {
  number: number;
  title: string;
  description: string;
  code?: string;
  codeVariant?: 'dark' | 'light';
}

const {
  number,
  title,
  description,
  code,
  codeVariant = 'dark',
} = Astro.props;

const codeClasses = codeVariant === 'dark'
  ? 'bg-base-900 text-base-50'
  : 'bg-primary-50 text-primary-700';
---

<div class="bg-white rounded-3xl border-2 border-base-200 p-8 hover:border-primary-300 transition-all">
  <div class="w-12 h-12 bg-primary-600 text-white rounded-full flex items-center justify-center text-xl font-bold mb-6">
    {number}
  </div>
  <h3 class="text-xl font-semibold mb-3">{title}</h3>
  <p class="text-base-600 mb-4">{description}</p>
  {code && (
    <div class={`${codeClasses} rounded-lg p-3 text-sm font-mono whitespace-pre-wrap wrap-break-word`}>
      <div class="whitespace-pre-wrap wrap-break-word">{code}</div>
    </div>
  )}
</div>
