---
/**
 * Desktop-only vertical phase rail for /s/:slug (≥ lg:).
 *
 * The mobile/tablet sticky chip bar is inlined in the page because it lives
 * above the grid, outside of this rail's grid column. Rendering one
 * component in two layout positions would duplicate markup and confuse
 * screen readers.
 */
import type { PhaseGroup, PhaseKey } from './classifyPhases'

type Props = {
  groups: PhaseGroup<unknown>[]
}

const { groups } = Astro.props

const phaseDescriptions: Record<PhaseKey, string> = {
  investigating: 'Reading, searching, understanding.',
  planning: 'Questions, plans, and to-dos.',
  building: 'Writing and editing code.',
  validating: 'Tests, checks, and cleanup.',
  summary: 'Final recap.',
}
---

{groups.length > 1 ? (
  <nav
    aria-label="Phases"
    class="sticky top-24 self-start"
  >
    <p class="text-muted-foreground mb-3 text-xs font-medium tracking-wide uppercase">
      Phases
    </p>
    <ol role="list" class="relative flex flex-col gap-0">
      <div
        class="bg-border absolute top-3 bottom-3 left-[0.4375rem] w-px"
        aria-hidden="true"
      ></div>
      {groups.map((group) => (
        <li class="relative flex items-start gap-3 py-2.5">
          <span
            class="bg-background border-border relative z-10 mt-0.5 inline-flex size-3.5 shrink-0 items-center justify-center rounded-full border-2"
            aria-hidden="true"
          >
            <span class="bg-primary size-1.5 rounded-full"></span>
          </span>
          <a
            href={`#${group.anchor}`}
            class="group flex min-w-0 flex-col gap-0.5 text-sm"
          >
            <span class="text-foreground group-hover:text-primary font-medium transition-colors">
              {group.label}
            </span>
            <span class="text-muted-foreground text-xs">
              {phaseDescriptions[group.phase]}
            </span>
            <span class="text-muted-foreground tabular-nums text-[0.6875rem]">
              {group.blocks.length} {group.blocks.length === 1 ? 'block' : 'blocks'}
            </span>
          </a>
        </li>
      ))}
    </ol>
  </nav>
) : null}
