{
  "name": "howicc",
  "version": "2.2.0",
  "description": "HowiCC CLI for inspecting, exporting, and eventually syncing local coding-agent conversations",
  "license": "MIT",
  "main": "./dist/index.cjs",
  "types": "./dist/index.d.cts",
  "exports": {
    ".": {
      "types": "./dist/index.d.cts",
      "require": "./dist/index.cjs",
      "default": "./dist/index.cjs"
    }
  },
  "author": {
    "name": "Abdallah Othman",
    "email": "contact@abdallahaho.com",
    "url": "https://abdallahaho.com"
  },
  "type": "module",
  "bin": {
    "howicc": "bin/howicc.cjs",
    "howi": "bin/howicc.cjs"
  },
  "files": [
    "dist",
    "bin",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "prepack": "pnpm run build",
    "prepublishOnly": "pnpm run build",
    "pack:dry-run": "pnpm pack",
    "type-check": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run --passWithNoTests"
  },
  "homepage": "https://howi.cc",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AbdallahAHO/howicc.git",
    "directory": "apps/cli"
  },
  "bugs": {
    "url": "https://github.com/AbdallahAHO/howicc/issues"
  },
  "keywords": [
    "claude-code",
    "ai",
    "cli",
    "transcripts",
    "analytics"
  ],
  "devDependencies": {
    "@howicc/api-client": "workspace:*",
    "@howicc/canonical": "workspace:*",
    "@howicc/model-pricing": "workspace:*",
    "@howicc/parser-core": "workspace:*",
    "@howicc/privacy": "workspace:*",
    "@howicc/profile": "workspace:*",
    "@howicc/provider-claude-code": "workspace:*",
    "@howicc/render": "workspace:*",
    "@howicc/storage": "workspace:*",
    "@howicc/typescript-config": "workspace:*",
    "@inquirer/prompts": "^8.4.1",
    "@types/node": "^25.6.0",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "conf": "^15.1.0",
    "ora": "^9.3.0",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.4",
    "zod": "^4.3.6"
  },
  "publishConfig": {
    "provenance": true
  },
  "engines": {
    "node": ">=24.0.0"
  }
}
