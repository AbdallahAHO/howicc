---
type Props = {
  label: string
  class?: string
  title?: string
}

const { label, class: className, title } = Astro.props
---

<code
  title={title}
  class:list={[
    'bg-accent text-primary border-primary/10 inline-flex max-w-[24ch] truncate rounded-pill border px-2 py-0.5 font-mono text-[0.75rem] shadow-2xs',
    className,
  ]}
>
  {label}
</code>
