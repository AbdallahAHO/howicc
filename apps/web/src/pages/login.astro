---
import Layout from '../components/Layout.astro'
import GithubSignInIsland from '../components/auth/GithubSignInIsland'
import { resolveLoginCallbackUrl } from '../lib/auth/login'
import type { WebLocals } from '../lib/auth/types'

const locals = Astro.locals as WebLocals

if (locals.auth.user) {
  return Astro.redirect('/home')
}

const callbackUrl = resolveLoginCallbackUrl({
  siteUrl: locals.siteUrl,
  requestedReturnTo: Astro.url.searchParams.get('returnTo'),
})
---

<Layout title="Sign in">
  <main class="grid min-h-dvh place-items-center px-4 py-16">
    <div class="w-full max-w-[26rem]">
      <div class="mb-10 flex flex-col items-center gap-3 text-center">
        <a href="/" class="inline-flex items-center gap-2 text-base font-semibold tracking-tight">
          <span class="bg-primary text-primary-foreground grid size-8 place-items-center rounded-lg text-sm font-bold tabular-nums">H</span>
          {locals.productName}
        </a>
      </div>

      <div class="bg-card text-card-foreground rounded-2xl border p-8 shadow-sm">
        <div class="flex flex-col gap-2 text-center">
          <h1 class="text-2xl font-semibold tracking-tight">Sign in or create your account</h1>
          <p class="text-muted-foreground text-sm">
            Authenticate with GitHub. We'll create an account on your first sign-in — no password needed.
          </p>
        </div>

        <div class="mt-8">
          <GithubSignInIsland
            client:load
            authApiUrl={locals.authApiUrl}
            callbackUrl={callbackUrl}
          />
        </div>

        <p class="text-muted-foreground mt-6 text-center text-xs">
          By continuing you agree to authenticate via GitHub OAuth. We only request <code class="bg-muted rounded px-1 py-0.5">read:user</code> and <code class="bg-muted rounded px-1 py-0.5">user:email</code>.
        </p>
      </div>

      <p class="text-muted-foreground mt-6 text-center text-xs">
        <a href="/" class="hover:text-foreground underline-offset-4 hover:underline">Back to home</a>
      </p>
    </div>
  </main>
</Layout>
