---
import type { RenderQuestionBlock } from '@howicc/contracts'
import { Badge } from '@howicc/ui-web/badge'
import BlockHeader from './shared/BlockHeader.astro'
import CollapsibleBlockShell from './shared/CollapsibleBlockShell.astro'

type Props = {
  block: RenderQuestionBlock
}

const { block } = Astro.props

const outcomeLabel: Record<RenderQuestionBlock['outcome'], string> = {
  answered: 'Answered',
  declined: 'Declined',
  redirected: 'Redirected',
  finished_plan_interview: 'Finished plan interview',
}

const outcomeVariant: Record<RenderQuestionBlock['outcome'], 'default' | 'secondary' | 'outline'> = {
  answered: 'default',
  declined: 'outline',
  redirected: 'secondary',
  finished_plan_interview: 'secondary',
}
---

<CollapsibleBlockShell
  defaultOpen={!block.defaultCollapsed}
  ariaLabel={block.title}
>
  <BlockHeader
    slot="summary"
    title={block.title}
    meta={`Outcome: ${outcomeLabel[block.outcome].toLowerCase()}`}
    count={block.questions.length}
  >
    <Badge slot="action" variant={outcomeVariant[block.outcome]}>
      {outcomeLabel[block.outcome]}
    </Badge>
  </BlockHeader>

  {block.questions.length === 0 ? (
    <p class="text-muted-foreground text-sm">No questions captured.</p>
  ) : (
    <ol role="list" class="flex flex-col gap-4 text-sm">
      {block.questions.map((item, index) => (
        <li class="flex flex-col gap-1.5">
          <div class="flex items-start gap-2">
            <span class="text-muted-foreground tabular-nums shrink-0 text-xs">
              {index + 1}.
            </span>
            <div class="flex min-w-0 flex-col gap-0.5">
              <p class="text-foreground font-medium text-pretty">{item.question}</p>
              {item.multiSelect ? (
                <span class="text-muted-foreground text-[0.6875rem] font-medium tracking-wide uppercase">
                  Multi-select
                </span>
              ) : null}
            </div>
          </div>
          {item.answer ? (
            <p class="text-muted-foreground text-sm text-pretty pl-6">
              <span class="text-foreground">→</span> {item.answer}
            </p>
          ) : (
            <p class="text-muted-foreground pl-6 text-sm italic">
              No answer recorded.
            </p>
          )}
          {item.selectedPreview ? (
            <blockquote class="border-border/60 text-muted-foreground ml-6 border-l-2 pl-3 text-xs text-pretty italic">
              {item.selectedPreview}
            </blockquote>
          ) : null}
          {item.notes ? (
            <p class="text-muted-foreground pl-6 text-xs text-pretty">
              {item.notes}
            </p>
          ) : null}
        </li>
      ))}
    </ol>
  )}

  {block.feedbackText ? (
    <p class="border-border/60 text-muted-foreground mt-4 border-t pt-3 text-sm text-pretty">
      {block.feedbackText}
    </p>
  ) : null}
</CollapsibleBlockShell>
