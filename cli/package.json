{
  "name": "@howicc/cli",
  "version": "1.0.0",
  "description": "Share your Claude Code conversations to howi.cc - like Pastebin for AI chats",
  "license": "MIT",
  "author": {
    "name": "Abdallah Othman",
    "email": "contact@abdallahaho.com",
    "url": "https://abdallahaho.com"
  },
  "type": "module",
  "bin": {
    "howicc": "./dist/index.js",
    "howi": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "type-check": "tsc --noEmit",
    "test": "vitest",
    "prepublishOnly": "pnpm build",
    "start": "pnpm build && node ./dist/index.js"
  },
  "keywords": [
    "claude",
    "claude-code",
    "ai",
    "conversation",
    "paste",
    "share",
    "cli"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/AbdallahAHO/howicc.git",
    "directory": "cli"
  },
  "bugs": {
    "url": "https://github.com/AbdallahAHO/howicc/issues"
  },
  "homepage": "https://howi.cc",
  "dependencies": {
    "@howicc/schemas": "workspace:*",
    "@inquirer/core": "^10.3.1",
    "@inquirer/prompts": "^7.2.0",
    "chalk": "^5.4.1",
    "commander": "^12.1.0",
    "conf": "^13.0.1",
    "ora": "^8.1.1",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@vitest/coverage-v8": "^4.0.8",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^4.0.8"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
