{
  "name": "@howicc/api",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "homepage": "https://howi.cc",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AbdallahAHO/howicc.git",
    "directory": "apps/api"
  },
  "bugs": {
    "url": "https://github.com/AbdallahAHO/howicc/issues"
  },
  "scripts": {
    "dev": "pnpm exec wrangler dev --config wrangler.jsonc --port 8787 --ip 127.0.0.1",
    "build": "tsc -p tsconfig.json",
    "deploy:prod": "pnpm exec wrangler deploy --config wrangler.jsonc --domains api.howi.cc",
    "deploy:check": "pnpm exec wrangler deploy --config wrangler.jsonc --domains api.howi.cc --dry-run",
    "cf:deploy": "pnpm run deploy:prod",
    "db:reset:local": "rm -rf .wrangler/state/v3/d1",
    "db:migrate:local": "pnpm exec wrangler d1 migrations apply DB --local --config wrangler.jsonc",
    "db:migrate:prod": "pnpm exec wrangler d1 migrations apply DB --remote --config wrangler.jsonc",
    "db:prepare:local": "pnpm run db:reset:local && pnpm run db:migrate:local",
    "test": "vitest run --passWithNoTests",
    "type-check": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.14",
    "@hono/zod-openapi": "^0.18.4",
    "@howicc/auth": "workspace:*",
    "@howicc/canonical": "workspace:*",
    "@howicc/contracts": "workspace:*",
    "@howicc/db": "workspace:*",
    "@howicc/model-pricing": "workspace:*",
    "@howicc/profile": "workspace:*",
    "@howicc/storage": "workspace:*",
    "@scalar/hono-api-reference": "^0.5.184",
    "drizzle-orm": "^0.45.2",
    "envin": "^1.2.0",
    "hono": "^4.12.14",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@howicc/typescript-config": "workspace:*",
    "@types/node": "^25.6.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.4"
  }
}
