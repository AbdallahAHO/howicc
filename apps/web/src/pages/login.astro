---
import { resolveLoginCallbackUrl } from '../lib/auth/login'
import type { WebLocals } from '../lib/auth/types'

const locals = Astro.locals as WebLocals
const authApiUrl = locals.authApiUrl
const callbackUrl = resolveLoginCallbackUrl({
  siteUrl: locals.siteUrl,
  requestedReturnTo: Astro.url.searchParams.get('returnTo'),
})
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Sign in to {locals.productName}</title>
  </head>
  <body>
    <main style="max-width: 560px; margin: 4rem auto; font-family: Inter, system-ui, sans-serif; line-height: 1.6; padding: 0 1rem;">
      <h1>Sign in to {locals.productName}</h1>
      <p>
        Continue with GitHub to access your future private dashboard, sync flows, and CLI login bridge.
      </p>
      <button
        id="github-sign-in"
        data-auth-api-url={authApiUrl}
        data-callback-url={callbackUrl}
        style="margin-top: 1.5rem; display: inline-flex; align-items: center; justify-content: center; padding: 0.85rem 1.15rem; background: #111827; color: white; border-radius: 999px; border: none; font: inherit; cursor: pointer; text-decoration: none; font-weight: 600;"
      >
        Continue with GitHub
      </button>
      <p id="login-status" style="margin-top: 1rem; color: #6b7280;">
        This will redirect through Better Auth on <code>{authApiUrl}</code> and then continue to GitHub.
      </p>
    </main>

    <script>
      import { wireGithubLoginPage } from '../lib/auth/browser/login-page'

      wireGithubLoginPage()
    </script>
  </body>
</html>
