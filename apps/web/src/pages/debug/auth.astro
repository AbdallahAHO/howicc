---
import AuthActionsIsland from '../../components/auth/AuthActionsIsland'
import type { WebLocals } from '../../lib/auth/types'

const locals = Astro.locals as WebLocals
const auth = locals.auth
const authApiUrl = locals.authApiUrl
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Auth Debug - HowiCC</title>
  </head>
  <body>
    <main style="max-width: 980px; margin: 3rem auto; font-family: Inter, system-ui, sans-serif; line-height: 1.65; padding: 0 1rem;">
      <section style="border: 1px solid #e5e7eb; border-radius: 1.25rem; padding: 2rem; background: white;">
        <h1 style="font-size: 3rem; margin: 0 0 0.5rem;">Dashboard - Hono</h1>
        <p style="margin: 0 0 2rem; color: #6b7280;">Powered by Better Auth, SSR session helpers, and a protected React island demo.</p>

        <p style="font-size: 2rem; font-weight: 700; margin-bottom: 1.5rem;">
          Status: {auth.user ? 'Logged In' : 'Not Logged In'}
        </p>

        {auth.user ? (
          <>
            <div style="display: grid; gap: 0.85rem; font-size: 1.15rem;">
              <div><strong>Welcome:</strong> {auth.user.name}</div>
              <div><strong>Email:</strong> {auth.user.email}</div>
              <div><strong>User ID:</strong> {auth.user.id}</div>
              <div><strong>Session ID:</strong> {auth.session?.id}</div>
              <div><strong>Session status:</strong> {auth.status}</div>
            </div>

            <AuthActionsIsland client:load apiUrl={authApiUrl} />
          </>
        ) : (
          <div style="display: flex; gap: 1rem; flex-wrap: wrap; align-items: center;">
            <a href="/login" style="display: inline-flex; align-items: center; justify-content: center; padding: 0.85rem 1.15rem; background: #2563eb; color: white; border-radius: 0.75rem; text-decoration: none; font-weight: 600;">
              Login with GitHub
            </a>
            <a href="/dashboard" style="display: inline-flex; align-items: center; justify-content: center; padding: 0.85rem 1.15rem; border: 1px solid #d1d5db; color: #111827; border-radius: 0.75rem; text-decoration: none;">
              Try protected page
            </a>
          </div>
        )}
      </section>
    </main>
  </body>
</html>
