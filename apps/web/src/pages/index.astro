---
import Layout from '../components/Layout.astro'
import type { WebLocals } from '../lib/auth/types'

const locals = Astro.locals as WebLocals
const apiHealthUrl = new URL('/health', locals.authApiUrl).toString()
const user = locals.auth.user
---

<Layout>
  <header class="border-border/60 border-b">
    <div class="mx-auto flex w-full max-w-6xl items-center justify-between gap-4 px-4 py-4">
      <a href="/" class="inline-flex items-center gap-2 text-base font-semibold tracking-tight">
        <span class="bg-primary text-primary-foreground grid size-8 place-items-center rounded-lg text-sm font-bold tabular-nums">H</span>
        {locals.productName}
      </a>
      <nav class="flex items-center gap-2 text-sm">
        <a
          href={apiHealthUrl}
          target="_blank"
          rel="noreferrer"
          class="text-muted-foreground hover:text-foreground hidden px-3 py-2 sm:inline-flex"
        >
          API health
        </a>
        {user ? (
          <a
            href="/dashboard"
            class="bg-primary text-primary-foreground hover:bg-primary/90 inline-flex h-9 items-center justify-center rounded-md px-4 text-sm font-medium transition-colors"
          >
            Open dashboard
          </a>
        ) : (
          <a
            href="/login"
            class="bg-primary text-primary-foreground hover:bg-primary/90 inline-flex h-9 items-center justify-center rounded-md px-4 text-sm font-medium transition-colors"
          >
            Sign in
          </a>
        )}
      </nav>
    </div>
  </header>

  <main class="mx-auto flex w-full max-w-3xl flex-col items-start gap-8 px-4 py-20 md:py-28">
    <span class="border-border bg-muted/40 text-muted-foreground inline-flex items-center gap-2 rounded-full border px-3 py-1 text-xs font-medium">
      <span class="bg-primary size-1.5 rounded-full"></span>
      Now running on canonical sessions
    </span>

    <h1 class="max-w-[20ch] text-5xl font-semibold tracking-tight text-balance md:text-6xl">
      Share your AI coding sessions as readable web pages.
    </h1>

    <p class="text-muted-foreground max-w-[48ch] text-lg text-pretty">
      HowiCC turns Claude Code, Codex, and other coding-agent transcripts into
      structured, shareable conversations — with cost, model, and tool-use insights baked in.
    </p>

    <div class="flex flex-wrap items-center gap-3">
      {user ? (
        <>
          <a
            href="/dashboard"
            class="bg-primary text-primary-foreground hover:bg-primary/90 inline-flex h-11 items-center justify-center rounded-md px-6 text-sm font-medium transition-colors"
          >
            Welcome back, {user.name?.split(' ')[0] ?? 'friend'} → Dashboard
          </a>
        </>
      ) : (
        <>
          <a
            href="/login"
            class="bg-primary text-primary-foreground hover:bg-primary/90 inline-flex h-11 items-center justify-center rounded-md px-6 text-sm font-medium transition-colors"
          >
            Continue with GitHub
          </a>
          <a
            href="/login"
            class="border-input bg-background hover:bg-accent hover:text-accent-foreground inline-flex h-11 items-center justify-center rounded-md border px-6 text-sm font-medium transition-colors"
          >
            Create account
          </a>
        </>
      )}
    </div>

    <dl class="text-muted-foreground mt-12 grid gap-2 text-xs">
      <div class="flex gap-2">
        <dt class="font-medium">Web</dt>
        <dd><code>{locals.siteUrl}</code></dd>
      </div>
      <div class="flex gap-2">
        <dt class="font-medium">API</dt>
        <dd><code>{locals.authApiUrl}</code></dd>
      </div>
    </dl>
  </main>
</Layout>
