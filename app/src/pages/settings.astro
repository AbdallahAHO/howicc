---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { StatsResponseSchema } from '@howicc/schemas';
import type { StatsResponse } from '@howicc/schemas';

export const prerender = false;

// Fetch stats from API
let stats: StatsResponse = {
  totalConversations: 0,
  publicConversations: 0,
  totalTags: 0,
};

try {
  const statsRes = await fetch(`${Astro.url.origin}/api/stats`);
  if (statsRes.ok) {
    const data = await statsRes.json();
    // Validate response with Zod schema
    stats = StatsResponseSchema.parse(data);
  }
} catch (error) {
  console.error('Failed to fetch stats:', error);
}

const apiUrl = import.meta.env.PUBLIC_SITE_URL || 'http://localhost:4321';
const isDemoMode = import.meta.env.DEMO_MODE === 'true';
---

<BaseLayout
  title="Settings | HowiCC"
  description="Configure your HowiCC instance and CLI settings"
>
  <div class="max-w-4xl mx-auto px-4 py-12">
    <!-- Header -->
    <div class="mb-8 flex justify-between items-center">
      <div>
        <h1 class="text-4xl font-bold text-base-900 mb-2">Settings</h1>
        <p class="text-base-600">Configure your HowiCC instance and CLI</p>
      </div>
      <div id="auth-status">
        <!-- Will be populated by client-side script -->
      </div>
    </div>

    <!-- Authentication Required Message -->
    <div id="auth-required" class="hidden bg-blue-50 border-l-4 border-blue-400 p-4 mb-8">
      <div class="flex">
        <div class="shrink-0">
          <svg class="h-5 w-5 text-blue-400" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z" clip-rule="evenodd" />
          </svg>
        </div>
        <div class="ml-3">
          <p class="text-sm text-blue-700">
            <strong>Sign in required:</strong> Please <a href="/login" class="underline font-medium">sign in</a> or <a href="/register" class="underline font-medium">create an account</a> to manage your API keys and view personalized settings.
          </p>
        </div>
      </div>
    </div>

    <!-- Demo Mode Warning -->
    {isDemoMode && (
      <div class="bg-yellow-50 border-l-4 border-yellow-400 p-4 mb-8">
        <div class="flex">
          <div class="shrink-0">
            <svg class="h-5 w-5 text-yellow-400" viewBox="0 0 20 20" fill="currentColor">
              <path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd" />
            </svg>
          </div>
          <div class="ml-3">
            <p class="text-sm text-yellow-700">
              <strong>Demo Mode Enabled:</strong> API authentication is disabled. Anyone can upload conversations without an API key.
            </p>
          </div>
        </div>
      </div>
    )}

    <!-- Stats -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
      <div class="bg-white rounded-lg border border-base-200 p-6">
        <div class="text-3xl font-bold text-primary-600 mb-1">{stats.totalConversations}</div>
        <div class="text-sm text-base-600">Total Conversations</div>
      </div>
      <div class="bg-white rounded-lg border border-base-200 p-6">
        <div class="text-3xl font-bold text-primary-600 mb-1">{stats.publicConversations}</div>
        <div class="text-sm text-base-600">Public Conversations</div>
      </div>
      <div class="bg-white rounded-lg border border-base-200 p-6">
        <div class="text-3xl font-bold text-primary-600 mb-1">{stats.totalTags}</div>
        <div class="text-sm text-base-600">Total Tags</div>
      </div>
    </div>

    <!-- API Keys Management (shown when logged in) -->
    <section id="api-keys-section" class="hidden bg-white rounded-lg border border-base-200 p-6 mb-6">
      <div class="flex justify-between items-center mb-4">
        <h2 class="text-2xl font-semibold text-base-900">Your API Keys</h2>
        <button
          id="generate-key-btn"
          class="px-4 py-2 bg-primary-600 text-white rounded-lg hover:bg-primary-700 transition-colors text-sm font-medium"
        >
          + Generate New Key
        </button>
      </div>

      <p class="text-sm text-base-600 mb-4">
        Use these API keys to authenticate the HowiCC CLI and upload your conversations.
      </p>

      <!-- API Keys List -->
      <div id="api-keys-list" class="space-y-3">
        <!-- Will be populated by client-side script -->
      </div>

      <div id="no-keys-message" class="hidden text-center py-8 text-base-500">
        <p>No API keys yet. Generate one to get started!</p>
      </div>

      <!-- New Key Modal Content (hidden by default) -->
      <div id="new-key-modal" class="hidden mt-6 p-4 bg-green-50 border border-green-200 rounded-lg">
        <div class="flex items-start gap-3">
          <svg class="w-6 h-6 text-green-600 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          <div class="flex-1">
            <h3 class="font-semibold text-green-900 mb-2">New API Key Generated!</h3>
            <p class="text-sm text-green-800 mb-3">
              <strong>Important:</strong> Copy this key now. You won't be able to see it again!
            </p>
            <div class="flex items-center gap-2">
              <input
                type="text"
                id="new-key-value"
                readonly
                class="flex-1 px-3 py-2 border border-green-300 rounded-lg bg-white font-mono text-sm"
              />
              <button
                onclick="copyNewKey()"
                id="copy-new-key-btn"
                class="px-4 py-2 bg-green-600 text-white rounded-lg hover:bg-green-700 transition-colors whitespace-nowrap"
              >
                Copy
              </button>
            </div>
            <button
              onclick="closeNewKeyModal()"
              class="mt-3 text-sm text-green-700 hover:text-green-800 underline"
            >
              I've copied it, close this
            </button>
          </div>
        </div>
      </div>
    </section>

    <!-- CLI Configuration -->
    <section class="bg-white rounded-lg border border-base-200 p-6 mb-6">
      <h2 class="text-2xl font-semibold text-base-900 mb-4">CLI Configuration</h2>

      <div class="space-y-4">
        <!-- API URL -->
        <div>
          <label class="block text-sm font-medium text-base-700 mb-2">API URL</label>
          <div class="flex items-center gap-2">
            <input
              type="text"
              value={apiUrl}
              readonly
              class="flex-1 px-4 py-2 border border-base-300 rounded-lg bg-base-50 font-mono text-sm"
              id="api-url"
            />
            <button
              onclick="copyToClipboard('api-url', this)"
              class="px-4 py-2 bg-primary-600 text-white rounded-lg hover:bg-primary-700 transition-colors"
            >
              Copy
            </button>
          </div>
        </div>
      </div>

      <!-- Setup Instructions -->
      <div class="mt-6 pt-6 border-t border-base-200">
        <h3 class="text-lg font-semibold text-base-900 mb-3">Setup CLI</h3>
        <div class="space-y-3">
          <div>
            <p class="text-sm text-base-700 mb-2">1. Configure the CLI:</p>
            <div class="bg-base-900 text-base-50 p-3 rounded-lg font-mono text-sm overflow-x-auto">
              npx howicc config
            </div>
          </div>

          <div>
            <p class="text-sm text-base-700 mb-2">2. When prompted, enter:</p>
            <ul class="list-disc list-inside text-sm text-base-600 space-y-1 ml-2">
              <li>API URL: <code class="px-1 py-0.5 bg-base-100 rounded">{apiUrl}</code></li>
              <li id="api-key-instruction">API Key: (generate one above after signing in)</li>
            </ul>
          </div>

          <div>
            <p class="text-sm text-base-700 mb-2">3. Sync your conversations:</p>
            <div class="bg-base-900 text-base-50 p-3 rounded-lg font-mono text-sm overflow-x-auto">
              npx howicc sync --recent 5
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Environment Configuration -->
    <section class="bg-white rounded-lg border border-base-200 p-6">
      <h2 class="text-2xl font-semibold text-base-900 mb-4">Environment</h2>

      <div class="space-y-3">
        <div class="flex justify-between items-center py-2 border-b border-base-100">
          <span class="text-sm font-medium text-base-700">PocketBase URL</span>
          <code class="text-sm text-base-600 bg-base-50 px-2 py-1 rounded">{import.meta.env.PB_URL}</code>
        </div>
        <div class="flex justify-between items-center py-2 border-b border-base-100">
          <span class="text-sm font-medium text-base-700">Demo Mode</span>
          <span class={`text-sm font-medium px-2 py-1 rounded ${isDemoMode ? 'bg-yellow-100 text-yellow-800' : 'bg-green-100 text-green-800'}`}>
            {isDemoMode ? 'Enabled' : 'Disabled'}
          </span>
        </div>
        <div class="flex justify-between items-center py-2 border-b border-base-100">
          <span class="text-sm font-medium text-base-700">OpenRouter Configured</span>
          <span class={`text-sm font-medium px-2 py-1 rounded ${import.meta.env.OPENROUTER_API_KEY ? 'bg-green-100 text-green-800' : 'bg-red-100 text-red-800'}`}>
            {import.meta.env.OPENROUTER_API_KEY ? 'Yes' : 'No'}
          </span>
        </div>
      </div>
    </section>

    <!-- Back to Home -->
    <div class="mt-8 text-center">
      <a href="/" class="text-primary-600 hover:text-primary-700 font-medium">
        ← Back to Home
      </a>
    </div>
  </div>
</BaseLayout>

<script>
  // @ts-nocheck
  let currentUser = null;

  // Check authentication status
  async function checkAuth() {
    try {
      const response = await fetch('/api/me', {
        method: 'GET',
        credentials: 'include',
      });

      const data = await response.json();
      // Type-safe handling - API returns validated UserResponseSchema
      // Response is validated server-side, so we can trust the structure
      currentUser = data.user;

      if (currentUser) {
        // Show logged in UI
        document.getElementById('auth-status').innerHTML = `
          <div class="flex items-center gap-3">
            <span class="text-sm text-base-700">
              <span class="font-medium">${currentUser.email}</span>
            </span>
            <button
              onclick="logout()"
              class="px-3 py-1.5 text-sm bg-base-200 text-base-700 rounded-lg hover:bg-base-300 transition-colors"
            >
              Sign Out
            </button>
          </div>
        `;

        // Show API keys section
        document.getElementById('api-keys-section').classList.remove('hidden');
        document.getElementById('auth-required').classList.add('hidden');

        // Load API keys
        await loadApiKeys();
      } else {
        // Show auth required message
        document.getElementById('auth-required').classList.remove('hidden');
        document.getElementById('auth-status').innerHTML = `
          <div class="flex items-center gap-3">
            <a
              href="/login"
              class="px-4 py-2 text-sm bg-primary-600 text-white rounded-lg hover:bg-primary-700 transition-colors font-medium"
            >
              Sign In
            </a>
            <a
              href="/register"
              class="px-4 py-2 text-sm bg-white border border-base-300 text-base-900 rounded-lg hover:bg-base-50 transition-colors font-medium"
            >
              Register
            </a>
          </div>
        `;
      }
    } catch (error) {
      console.error('Auth check failed:', error);
    }
  }

  // Load API keys for the current user
  async function loadApiKeys() {
    try {
      const response = await fetch('/api/keys', {
        method: 'GET',
        credentials: 'include',
      });

      if (!response.ok) {
        throw new Error('Failed to load API keys');
      }

      const data = await response.json();
      // Type-safe handling - API returns validated APIKeysResponseSchema
      // Response is validated server-side, so we can trust the structure
      const keys = data.keys || [];

      const list = document.getElementById('api-keys-list');
      const noKeysMsg = document.getElementById('no-keys-message');

      if (keys.length === 0) {
        list.innerHTML = '';
        noKeysMsg.classList.remove('hidden');
      } else {
        noKeysMsg.classList.add('hidden');
        list.innerHTML = keys.map(key => `
          <div class="flex items-center justify-between p-4 border border-base-200 rounded-lg">
            <div class="flex-1">
              <div class="font-mono text-sm text-base-900 mb-1">
                ${key.name || 'API Key'}
              </div>
              <div class="flex items-center gap-3 text-xs text-base-600">
                <span>Created: ${new Date(key.created).toLocaleDateString()}</span>
                ${key.last_used ? `<span>Last used: ${new Date(key.last_used).toLocaleDateString()}</span>` : '<span>Never used</span>'}
              </div>
            </div>
            <button
              onclick="deleteKey('${key.id}')"
              class="px-3 py-1.5 text-sm text-red-600 hover:bg-red-50 rounded-lg transition-colors"
            >
              Delete
            </button>
          </div>
        `).join('');
      }
    } catch (error) {
      console.error('Failed to load API keys:', error);
    }
  }

  // Generate new API key
  async function generateNewKey() {
    const btn = document.getElementById('generate-key-btn');
    btn.disabled = true;
    btn.textContent = 'Generating...';

    try {
      const response = await fetch('/api/keys', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
        },
        credentials: 'include',
        body: JSON.stringify({
          name: 'API Key',
        }),
      });

      const data = await response.json();

      if (response.ok) {
        // Type-safe handling - API returns validated CreateAPIKeyResponseSchema
        // Response is validated server-side, so we can trust the structure
        if (data.key) {
          // Show the new key
          document.getElementById('new-key-value').value = data.key;
          document.getElementById('new-key-modal').classList.remove('hidden');

          // Reload keys list
          await loadApiKeys();
        } else {
          throw new Error('Invalid response format');
        }
      } else {
        // Type-safe error handling - API returns validated APIErrorSchema
        const errorMessage = data?.error || 'Failed to generate API key';
        alert('Failed to generate API key: ' + errorMessage);
      }
    } catch (error) {
      console.error('Failed to generate key:', error);
      alert('Failed to generate API key');
    } finally {
      btn.disabled = false;
      btn.textContent = '+ Generate New Key';
    }
  }

  // Delete API key
  async function deleteKey(keyId) {
    if (!confirm('Are you sure you want to delete this API key? This cannot be undone.')) {
      return;
    }

    try {
      const response = await fetch(`/api/keys?id=${keyId}`, {
        method: 'DELETE',
        credentials: 'include',
      });

      const result = await response.json();

      if (response.ok) {
        await loadApiKeys();
      } else {
        alert('Failed to delete API key: ' + result.error);
      }
    } catch (error) {
      console.error('Failed to delete key:', error);
      alert('Failed to delete API key');
    }
  }

  // Logout
  async function logout() {
    try {
      await fetch('/api/logout', {
        method: 'POST',
        credentials: 'include',
      });
    } catch (error) {
      console.error('Logout error:', error);
    } finally {
      window.location.reload();
    }
  }

  // Copy new key
  function copyNewKey() {
    const input = document.getElementById('new-key-value');
    const button = document.getElementById('copy-new-key-btn');

    navigator.clipboard.writeText(input.value).then(() => {
      const originalText = button.textContent;
      button.textContent = 'Copied!';
      button.classList.add('bg-green-700');

      setTimeout(() => {
        button.textContent = originalText;
        button.classList.remove('bg-green-700');
      }, 2000);
    });
  }

  // Close new key modal
  function closeNewKeyModal() {
    document.getElementById('new-key-modal').classList.add('hidden');
    document.getElementById('new-key-value').value = '';
  }

  function copyToClipboard(inputId, button) {
    const input = document.getElementById(inputId);
    if (!input) return;

    navigator.clipboard.writeText(input.value).then(() => {
      const originalText = button.textContent;
      button.textContent = 'Copied!';
      button.classList.add('bg-green-600');
      button.classList.remove('bg-primary-600', 'hover:bg-primary-700');

      setTimeout(() => {
        button.textContent = originalText;
        button.classList.remove('bg-green-600');
        button.classList.add('bg-primary-600', 'hover:bg-primary-700');
      }, 2000);
    });
  }

  // Initialize
  document.getElementById('generate-key-btn')?.addEventListener('click', generateNewKey);

  // Make functions globally accessible
  window.copyToClipboard = copyToClipboard;
  window.copyNewKey = copyNewKey;
  window.closeNewKeyModal = closeNewKeyModal;
  window.deleteKey = deleteKey;
  window.logout = logout;

  // Check auth on page load
  checkAuth();
</script>
