---
import Layout from '../components/Layout.astro'
import type { WebLocals } from '../lib/auth/types'

const locals = Astro.locals as WebLocals
const user = locals.auth.user
---

<Layout>
  <div class="archive-glow min-h-dvh">
    <header class="border-border/60 bg-background/88 border-b">
      <div class="mx-auto flex w-full max-w-6xl items-center justify-between gap-4 px-4 py-4">
        <a href="/" class="inline-flex items-center gap-2 text-base font-semibold tracking-tight">
          <span class="bg-primary text-primary-foreground grid size-8 place-items-center rounded-lg text-sm font-bold tabular-nums">H</span>
          {locals.productName}
        </a>
        <nav class="flex items-center gap-2 text-sm">
          {user ? (
            <a
              href="/home"
              class="bg-primary text-primary-foreground hover:bg-primary/90 inline-flex h-9 items-center justify-center rounded-md px-4 text-sm font-medium transition-colors"
            >
              Open dashboard
            </a>
          ) : (
            <a
              href="/login"
              class="bg-primary text-primary-foreground hover:bg-primary/90 inline-flex h-9 items-center justify-center rounded-md px-4 text-sm font-medium transition-colors"
            >
              Sign in
            </a>
          )}
        </nav>
      </div>
    </header>

    <main class="mx-auto flex w-full max-w-3xl flex-col items-start gap-8 px-4 py-20 md:py-28">
      <h1 class="archive-page-title max-w-[18ch] text-5xl md:text-6xl">
        Share your AI coding sessions as readable web pages.
      </h1>

      <p class="text-ink-secondary max-w-[52ch] text-lg text-pretty">
        A quiet home for the coding sessions you actually want to keep — readable, searchable, and yours to share.
      </p>

      <div class="flex flex-wrap items-center gap-3">
        {user ? (
          <a
            href="/home"
            class="bg-primary text-primary-foreground hover:bg-primary/90 inline-flex h-11 items-center justify-center rounded-md px-6 text-sm font-medium transition-colors"
          >
            Open your dashboard
          </a>
        ) : (
          <a
            href="/login"
            class="bg-primary text-primary-foreground hover:bg-primary/90 inline-flex h-11 items-center justify-center rounded-md px-6 text-sm font-medium transition-colors"
          >
            Continue with GitHub
          </a>
        )}
      </div>
    </main>

    <footer class="border-border/60 mt-auto border-t">
      <div class="text-ink-tertiary mx-auto flex w-full max-w-3xl flex-wrap items-center justify-between gap-3 px-4 py-6 text-xs">
        <p class="text-pretty">
          An indie project. Light mode, warm paper, no tracking pixels.
        </p>
        <nav class="flex items-center gap-4">
          <a
            href="https://github.com/AbdallahAHO/howicc"
            class="hover:text-foreground"
            rel="noreferrer"
            target="_blank"
          >
            GitHub
          </a>
        </nav>
      </div>
    </footer>
  </div>
</Layout>
