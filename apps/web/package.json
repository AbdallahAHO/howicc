{
  "name": "@howicc/web",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "homepage": "https://howi.cc",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AbdallahAHO/howicc.git",
    "directory": "apps/web"
  },
  "bugs": {
