{
  "name": "@howicc/storage",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "Provider-neutral storage interfaces and adapters for HowiCC",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./adapters": "./src/adapters/index.ts",
    "./adapters/r2": "./src/adapters/r2.ts",
    "./adapters/s3-compatible": "./src/adapters/s3-compatible.ts",
    "./compression": "./src/compression.ts",
    "./config": "./src/config.ts",
    "./keys": "./src/keys.ts",
    "./paths": "./src/paths.ts"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "test": "vitest run --passWithNoTests",
    "type-check": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.717.0",
    "@aws-sdk/s3-request-presigner": "^3.717.0",
    "envin": "^1.2.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@howicc/typescript-config": "workspace:*",
    "typescript": "^5.7.2",
    "vitest": "^3.0.5"
  }
}
