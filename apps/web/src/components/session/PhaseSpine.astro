---
/**
 * Desktop-only vertical phase rail for /s/:slug (≥ lg:).
 *
 * The mobile/tablet sticky chip bar is inlined in the page because it lives
 * above the grid, outside of this rail's grid column. Rendering one
 * component in two layout positions would duplicate markup and confuse
 * screen readers.
 */
import type { PhaseGroup, PhaseKey } from './classifyPhases'

type Props = {
  groups: PhaseGroup<unknown>[]
}

const { groups } = Astro.props

const phaseDescriptions: Record<PhaseKey, string> = {
  investigating: 'Reading, searching, understanding.',
  planning: 'Questions, plans, and to-dos.',
  building: 'Writing and editing code.',
  validating: 'Tests, checks, and cleanup.',
  summary: 'Final recap.',
}
---

{groups.length > 1 ? (
  <nav
    aria-label="Phases"
    class="bg-card/95 border-border/80 shadow-subtle sticky top-24 self-start rounded-lg border px-4 py-4"
  >
    <p class="text-ink-secondary mb-3 text-[0.6875rem] font-medium">
      Phases
    </p>
    <ol role="list" class="relative flex flex-col gap-1">
      <div
        class="bg-border absolute top-4 bottom-4 left-[0.95rem] w-px"
        aria-hidden="true"
      ></div>
      {groups.map((group, index) => (
        <li
          data-phase-link={group.anchor}
          data-active="false"
          class="group/phase-item relative flex items-start gap-3 py-2"
        >
          <span
            class="bg-background border-border text-ink-secondary group-data-[active=true]/phase-item:border-primary group-data-[active=true]/phase-item:bg-primary group-data-[active=true]/phase-item:text-primary-foreground shadow-subtle relative z-10 inline-flex size-8 shrink-0 items-center justify-center rounded-pill border font-mono text-[0.75rem] transition-colors"
            aria-hidden="true"
          >
            {index + 1}
          </span>
          <a
            href={`#${group.anchor}`}
            class="flex min-w-0 flex-col gap-0.5 pt-0.5 text-sm outline-none focus-visible:ring-2 focus-visible:ring-primary/20"
          >
            <span class="text-foreground group-hover/phase-item:text-primary group-data-[active=true]/phase-item:text-primary font-medium transition-colors">
              {group.label}
            </span>
            <span class="text-ink-secondary text-xs">
              {phaseDescriptions[group.phase]}
            </span>
            <span class="text-ink-tertiary tabular-nums text-[0.6875rem]">
              {group.blocks.length} {group.blocks.length === 1 ? 'block' : 'blocks'}
            </span>
          </a>
        </li>
      ))}
    </ol>
  </nav>
) : null}
