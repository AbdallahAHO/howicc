---
import Layout from '../../components/Layout.astro'
import AuthActionsIsland from '../../components/auth/AuthActionsIsland'
import type { WebLocals } from '../../lib/auth/types'

const locals = Astro.locals as WebLocals
const auth = locals.auth
const authApiUrl = locals.authApiUrl
---

<Layout title="Auth debug">
  <main class="mx-auto flex w-full max-w-3xl flex-col gap-8 px-4 py-16">
    <div class="flex flex-col gap-2">
      <h1 class="text-3xl font-semibold tracking-tight">Auth debug</h1>
      <p class="text-muted-foreground text-sm">SSR session helper, Better Auth, and the protected island demo.</p>
    </div>

    <section class="bg-card text-card-foreground rounded-2xl border p-6 shadow-sm">
      <p class="text-xs font-medium uppercase tracking-wide text-muted-foreground">Status</p>
      <p class="mt-2 text-2xl font-semibold tracking-tight">
        {auth.user ? 'Logged in' : 'Not logged in'}
      </p>

      {auth.user ? (
        <dl class="mt-6 grid gap-3 text-sm">
          <div class="border-border/60 grid grid-cols-[120px_1fr] gap-3 border-t py-3">
            <dt class="text-muted-foreground">Name</dt>
            <dd>{auth.user.name}</dd>
          </div>
          <div class="border-border/60 grid grid-cols-[120px_1fr] gap-3 border-t py-3">
            <dt class="text-muted-foreground">Email</dt>
            <dd>{auth.user.email}</dd>
          </div>
          <div class="border-border/60 grid grid-cols-[120px_1fr] gap-3 border-t py-3">
            <dt class="text-muted-foreground">User ID</dt>
            <dd class="font-mono text-xs">{auth.user.id}</dd>
          </div>
          <div class="border-border/60 grid grid-cols-[120px_1fr] gap-3 border-t py-3">
            <dt class="text-muted-foreground">Session ID</dt>
            <dd class="font-mono text-xs">{auth.session?.id}</dd>
          </div>
          <div class="border-border/60 grid grid-cols-[120px_1fr] gap-3 border-t py-3">
            <dt class="text-muted-foreground">Status</dt>
            <dd>{auth.status}</dd>
          </div>
        </dl>
      ) : (
        <div class="mt-6 flex flex-wrap gap-3">
          <a
            href="/login"
            class="bg-primary text-primary-foreground hover:bg-primary/90 inline-flex h-10 items-center justify-center rounded-md px-4 text-sm font-medium transition-colors"
          >
            Sign in with GitHub
          </a>
          <a
            href="/dashboard"
            class="border-input bg-background hover:bg-accent hover:text-accent-foreground inline-flex h-10 items-center justify-center rounded-md border px-4 text-sm font-medium transition-colors"
          >
            Try protected page
          </a>
        </div>
      )}
    </section>

    {auth.user ? (
      <section class="bg-card text-card-foreground rounded-2xl border p-6 shadow-sm">
        <h2 class="text-lg font-semibold">Account actions</h2>
        <div class="mt-5">
          <AuthActionsIsland client:load apiUrl={authApiUrl} />
        </div>
      </section>
    ) : null}
  </main>
</Layout>
