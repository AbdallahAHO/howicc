---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Button from '@/components/ui/Button.astro';
import InstallBlockWidget from '@/components/InstallBlockWidget';
---

<BaseLayout
  title="How I Claude Code - Share Your Claude Conversations"
  description="Transform your Claude Code conversations into beautifully formatted, shareable links. Like Pastebin for AI chats."
>
  <div class="px-8 py-24 mx-auto max-w-7xl md:px-12 lg:px-20">
    <div class="items-center grid grid-cols-1 lg:grid-cols-3 gap-12">
      <div>
        <h1 class="text-2xl md:text-3xl lg:text-4xl font-semibold tracking-tight text-base-900 lg:text-balance">
          Share your Claude conversations, beautifully
        </h1>
        <p class="text-sm mt-4 lg:text-balance text-base-600">
          Transform your local Claude Code conversations into shareable links with AI-powered summaries, automatic tags, and syntax highlighting.
        </p>
        <div class="flex flex-wrap items-center mx-auto mt-8 gap-2">
          <Button href="/register" variant="primary" size="md" class="rounded-md">
            Get started
          </Button>
          <Button href="#how-it-works" variant="secondary" size="md" class="rounded-md">
            How it works
          </Button>
        </div>
        <p class="text-xs relative font-semibold uppercase tracking-wide mt-8 text-primary-600">
          Built for developers, not just users
          <a href="#features" class="relative text-primary-600 hover:text-primary-700">
            <span class="absolute inset-0" aria-hidden="true"></span> See the details
          </a>
        </p>
      </div>
      <div class="lg:col-span-2">
        <div class="bg-linear-to-br from-primary-50 to-base-100 rounded-lg shadow-lg outline outline-base-200 p-12 aspect-video flex items-center justify-center">
          <div class="text-center">
            <div class="w-16 h-16 bg-primary-600 rounded-lg mx-auto mb-4 flex items-center justify-center">
              <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
              </svg>
            </div>
            <p class="text-base-600 font-medium">Conversation Preview</p>
            <p class="text-sm text-base-500 mt-2">With syntax highlighting and AI summaries</p>
          </div>
        </div>
      </div>
    </div>

    <dl class="mt-12 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-x-6 gap-y-8" id="features">
      <div>
        <div class="flex items-center text-primary-600 gap-2">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="size-5 text-primary-600"
          >
            <path stroke="none" d="M0 0h24v24H0z" fill="none"></path>
            <path d="M12 2a3 3 0 0 0 -3 3v7a3 3 0 0 0 6 0v-7a3 3 0 0 0 -3 -3z"></path>
            <path d="M19 10v2a7 7 0 0 1 -14 0v-2"></path>
            <path d="M12 18v4"></path>
            <path d="M8 22h8"></path>
          </svg>
          <dt>
            <h3 class="text-base font-medium m text-base-900">
              AI-powered analysis
            </h3>
          </dt>
        </div>
        <dd>
          <p class="text-sm mt-2 text-base-600">
            Automatic summaries, key takeaways, and relevant tags generated using Claude 3.5 Sonnet.
          </p>
        </dd>
      </div>

      <div>
        <div class="flex items-center text-primary-600 gap-2">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="size-5 text-primary-600"
          >
            <path stroke="none" d="M0 0h24v24H0z" fill="none"></path>
            <path d="M12 3a12 12 0 0 0 8.5 3a12 12 0 0 1 -8.5 15a12 12 0 0 1 -8.5 -15a12 12 0 0 0 8.5 -3"></path>
            <path d="M12 11m-1 0a1 1 0 1 0 2 0a1 1 0 1 0 -2 0"></path>
            <path d="M12 12l0 .01"></path>
          </svg>
          <dt>
            <h3 class="text-base font-medium m text-base-900">
              Privacy-first
            </h3>
          </dt>
        </div>
        <dd>
          <p class="text-sm mt-2 text-base-600">
            Private by default with automatic PII and secret detection. Your conversations stay yours.
          </p>
        </dd>
      </div>

      <div>
        <div class="flex items-center text-primary-600 gap-2">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="size-5 text-primary-600"
          >
            <path stroke="none" d="M0 0h24v24H0z" fill="none"></path>
            <path d="M3 12a9 9 0 1 0 18 0a9 9 0 0 0 -18 0"></path>
            <path d="M12 7v5l3 3"></path>
          </svg>
          <dt>
            <h3 class="text-base font-medium m text-base-900">
              Lightning fast
            </h3>
          </dt>
        </div>
        <dd>
          <p class="text-sm mt-2 text-base-600">
            Built with Astro SSR and PocketBase for instant page loads. No waiting, just sharing.
          </p>
        </dd>
      </div>

      <div>
        <div class="flex items-center text-primary-600 gap-2">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="size-5 text-primary-600"
          >
            <path stroke="none" d="M0 0h24v24H0z" fill="none"></path>
            <path d="M7 8l-4 4l4 4"></path>
            <path d="M17 8l4 4l-4 4"></path>
            <path d="M14 4l-4 16"></path>
          </svg>
          <dt>
            <h3 class="text-base font-medium m text-base-900">
              Developer-first
            </h3>
          </dt>
        </div>
        <dd>
          <p class="text-sm mt-2 text-base-600">
            CLI tool that respects your workflow. Sync conversations with a single command.
          </p>
        </dd>
      </div>
    </dl>

    <!-- How It Works Section -->
    <section class="mt-24" id="how-it-works">
      <div class="max-w-3xl mb-16">
        <h2 class="text-2xl md:text-3xl lg:text-4xl font-semibold tracking-tight text-base-900 text-balance">
          Get started in three simple steps
        </h2>
        <p class="text-base mt-2 font-medium text-base-600">
          Follow the steps below to set up your account and start sharing your conversations in minutes.
        </p>
      </div>

      <div class="relative flex flex-col items-center">
        <div
          data-orientation="horizontal"
          class="bg-base-200 shrink-0 data-[orientation=horizontal]:h-px data-[orientation=horizontal]:w-full data-[orientation=vertical]:h-full data-[orientation=vertical]:w-px absolute -top-12 left-0 hidden md:block"
        ></div>
        <div class="grid gap-6 md:grid-cols-3 w-full">
          <div class="relative p-6 shadow-sm space-y-3 bg-white outline outline-base-200 rounded-xl border border-base-200">
            <div
              data-orientation="vertical"
              role="none"
              class="shrink-0 data-[orientation=horizontal]:h-px data-[orientation=horizontal]:w-full data-[orientation=vertical]:h-full data-[orientation=vertical]:w-px absolute top-8 left-0 block md:hidden bg-base-200"
            ></div>
            <div class="absolute top-0 -left-[9px] z-10 flex size-10 items-center justify-center rounded-full bg-white p-1 md:-top-14 md:left-0 border-2 border-primary-600 shadow-sm">
              <span class="text-sm font-semibold text-base-900">1</span>
            </div>
            <div class="pl-7 md:pl-0 pt-2">
              <h3 class="text-base font-semibold tracking-tight text-base-900 mb-2">
                Install the CLI
              </h3>
              <p class="text-sm text-base-600 lg:text-balance mb-4 leading-relaxed">
                Use npx to run the CLI without installing globally.
              </p>
              <div class="bg-base-900 text-base-50 rounded-lg p-3 text-sm font-mono whitespace-pre-wrap wrap-break-word border border-base-800">npx @howicc/cli config</div>
            </div>
          </div>

          <div class="relative p-6 shadow-sm space-y-3 bg-white outline outline-base-200 rounded-xl border border-base-200">
            <div
              data-orientation="vertical"
              role="none"
              class="shrink-0 data-[orientation=horizontal]:h-px data-[orientation=horizontal]:w-full data-[orientation=vertical]:h-full data-[orientation=vertical]:w-px absolute top-8 left-0 block md:hidden bg-base-200"
            ></div>
            <div class="absolute top-0 -left-[9px] z-10 flex size-10 items-center justify-center rounded-full bg-white p-1 md:-top-14 md:left-0 border-2 border-primary-600 shadow-sm">
              <span class="text-sm font-semibold text-base-900">2</span>
            </div>
            <div class="pl-7 md:pl-0 pt-2">
              <h3 class="text-base font-semibold tracking-tight text-base-900 mb-2">
                Sync conversations
              </h3>
              <p class="text-sm text-base-600 lg:text-balance mb-4 leading-relaxed">
                Select which conversations to share with an interactive picker.
              </p>
              <div class="bg-base-900 text-base-50 rounded-lg p-3 text-sm font-mono whitespace-pre-wrap wrap-break-word border border-base-800">npx @howicc/cli sync</div>
            </div>
          </div>

          <div class="relative p-6 shadow-sm space-y-3 bg-white outline outline-base-200 rounded-xl border border-base-200">
            <div
              data-orientation="vertical"
              role="none"
              class="shrink-0 data-[orientation=horizontal]:h-px data-[orientation=horizontal]:w-full data-[orientation=vertical]:h-full data-[orientation=vertical]:w-px absolute top-8 left-0 block md:hidden bg-base-200"
            ></div>
            <div class="absolute top-0 -left-[9px] z-10 flex size-10 items-center justify-center rounded-full bg-white p-1 md:-top-14 md:left-0 border-2 border-primary-600 shadow-sm">
              <span class="text-sm font-semibold text-base-900">3</span>
            </div>
            <div class="pl-7 md:pl-0 pt-2">
              <h3 class="text-base font-semibold tracking-tight text-base-900 mb-2">
                Share the link
              </h3>
              <p class="text-sm text-base-600 lg:text-balance mb-4 leading-relaxed">
                Get a beautiful link with AI-generated summary and tags.
              </p>
                <div class="bg-primary-50 text-primary-700 rounded-lg p-3 text-sm font-mono whitespace-pre-wrap wrap-break-word border border-primary-200"><div class="text-primary-700 block">howi.cc/p/your-slug</div></div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Install Methods Section -->
    <section class="mt-24">
      <InstallBlockWidget client:load />
    </section>

    <!-- CTA Section -->
    <section class="mt-24 text-center">
      <div class="bg-linear-to-br from-primary-600 to-primary-700 rounded-lg p-12 text-white">
        <h2 class="text-3xl font-semibold mb-4">Ready to share your conversations?</h2>
        <p class="text-lg mb-8 text-primary-50 max-w-2xl mx-auto">
          Join developers sharing their Claude Code conversations and building in public.
        </p>
        <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
          <Button
            href="/register"
            variant="outline"
            size="md"
            class="rounded-md bg-white text-primary-700 hover:bg-primary-50"
          >
            Get started free
          </Button>
          <a
            href="https://github.com/AbdallahAHO/howicc"
            class="inline-flex items-center gap-2 px-6 py-3 bg-primary-800 text-white rounded-md font-medium hover:bg-primary-900 transition-all"
            target="_blank"
            rel="noopener"
          >
            <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24">
              <path
                fill-rule="evenodd"
                d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"
                clip-rule="evenodd"
              />
            </svg>
            View on GitHub
          </a>
        </div>
      </div>
    </section>
  </div>
</BaseLayout>

<style>
  code {
    font-family: 'Monaco', 'Courier New', monospace;
  }
</style>
