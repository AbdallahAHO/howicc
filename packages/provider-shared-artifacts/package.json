{
  "name": "@howicc/provider-shared-artifacts",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "Shared artifact extraction helpers for provider adapters",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
