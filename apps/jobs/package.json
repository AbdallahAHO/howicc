    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@howicc/typescript-config": "workspace:*",
    "@types/node": "^22.10.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^3.0.5"
  }
}
