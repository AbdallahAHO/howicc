---
import { Badge } from '@howicc/ui-web/badge'

type Status = 'ok' | 'error' | 'partial'

type Props = {
  status: Status
  class?: string
}

const { status, class: className } = Astro.props

const label: Record<Status, string> = {
  ok: 'ok',
  error: 'error',
  partial: 'partial',
}

const variant: Record<Status, 'outline' | 'secondary' | 'destructive'> = {
  ok: 'outline',
  partial: 'secondary',
  error: 'destructive',
}
---

<Badge variant={variant[status]} className={className}>{label[status]}</Badge>
