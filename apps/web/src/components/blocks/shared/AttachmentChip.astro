---
type Props = {
  label: string
  href?: string
}

const { label, href } = Astro.props

const baseClass =
  'border-border/60 bg-muted/30 text-foreground inline-flex max-w-[24ch] items-center gap-1.5 rounded-md border px-2.5 py-1 text-xs font-medium transition-colors'
---

{href ? (
  <a href={href} class:list={[baseClass, 'hover:bg-muted hover:border-border']}>
    <span class="truncate">{label}</span>
    <svg
      class="text-muted-foreground size-3 shrink-0"
      viewBox="0 0 16 16"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
      aria-hidden="true"
    >
      <path d="M6 4h6v6" />
      <path d="M12 4L5 11" />
    </svg>
  </a>
) : (
  <span class:list={[baseClass, 'text-muted-foreground']}>
    <span class="truncate">{label}</span>
  </span>
)}
